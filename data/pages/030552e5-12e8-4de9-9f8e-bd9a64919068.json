              "children": [
                {
                  "text": "00:05:16 - 00:06:22\t"
                },
                {
                  "text": "Sección 2: \"Pido castigo\" por Neruda",
                  "bold": true
                }
              ]
            }
          ]
        },
        {
          "type": "column",
          "children": [
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Se recitan versos de Pablo Neruda para exigir que los responsables de la represión y las muertes sean juzgados y castigados."
                }
              ]
            },
            {
              "type": "horizontal-separator",
              "children": [
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
