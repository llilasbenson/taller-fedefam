                  "text": "00:06:41 - 00:07:24\t"
                },
                {
                  "text": "Sección 3: Adhesiones",
                  "bold": true
                }
              ]
            }
          ]
        },
        {
          "type": "column",
          "children": [
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "La presentadora explica que, debido al gran número de adhesiones recibidas por FEDEFAM y al programa de oradores, solo podrán leerse algunas, mientras que las restantes serán exhibidas en el Hotel Castelar."
                }
              ]
            },
            {
              "type": "horizontal-separator",
              "children": [
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
